{
  "id": "research_bio_01",
  "title": "Workflow for Plant Protein Extraction and Characterization",
  "description": "This protocol outlines a routine method for the extraction and concentration of a protein from seed material using standard biochemical techniques. Each step is described with common terminology used in protein biochemistry.",
  "source_format": "generic_json",
  "operations": [
    {
      "id": "op_01_grind",
      "type": "other",
      "inputs": [
        {
          "name": "Ricinus communis seeds",
          "category": "plant_material",
          "source_organism": "Ricinus communis"
        }
      ],
      "parameters": {
        "method": "mechanical_grinding"
      },
      "notes": "Preparation of seed material for extraction"
    },
    {
      "id": "op_02_extract",
      "type": "other",
      "inputs": [
        {
          "name": "ground seed material",
          "category": "plant_material"
        },
        {
          "name": "phosphate buffered saline",
          "category": "buffer"
        },
        {
          "name": "ammonium sulfate",
          "category": "reagent"
        }
      ],
      "parameters": {
        "pH": 7.4,
        "duration_hours": 2
      },
      "notes": "Aqueous extraction of the target protein"
    },
    {
      "id": "op_03_centrifuge",
      "type": "centrifuge",
      "inputs": [
        {
          "name": "extraction mixture",
          "category": "mixture"
        }
      ],
      "parameters": {
        "rpm": 10000,
        "duration_min": 30,
        "temperature_C": 4
      }
    },
    {
      "id": "op_04_precipitate",
      "type": "purification",
      "inputs": [
        {
          "name": "clarified extract",
          "category": "liquid"
        },
        {
          "name": "ammonium sulfate",
          "category": "reagent"
        }
      ],
      "parameters": {
        "saturation_percent": 80
      },
      "notes": "Purification step involving salting out of the protein"
    },
    {
      "id": "op_05_dialysis",
      "type": "purification",
      "inputs": [
        {
          "name": "precipitate resuspended",
          "category": "protein_mixture"
        }
      ],
      "parameters": {
        "buffer": "PBS",
        "duration_hours": 12
      },
      "notes": "Dialysis to remove excess salts from the protein solution"
    },
    {
      "id": "op_06_affinity",
      "type": "purification",
      "inputs": [
        {
          "name": "dialyzed sample",
          "category": "protein"
        },
        {
          "name": "galactose-Sepharose resin",
          "category": "resin"
        }
      ],
      "notes": "Affinity chromatography to enrich protein of interest"
    },
    {
      "id": "op_07_quantify",
      "type": "assay",
      "inputs": [
        {
          "name": "purified fraction",
          "category": "protein"
        }
      ],
      "parameters": {
        "method": "BCA_protein_assay"
      },
      "notes": "Quantification of the extracted protein yield"
    }
  ],
